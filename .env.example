# ─── СКОПИРУЙ В .env И ЗАПОЛНИ ────────────────────────────────────────────────
# cp .env.example .env

# ─── Telegram API ─────────────────────────────────────────────────────────────
# Получить на: https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79001234567

# ─── NLP ──────────────────────────────────────────────────────────────────────
# Лёгкая и быстрая модель (~45MB):
NLP_MODEL=cointegrated/rubert-tiny-sentiment-balanced
# Точная модель (~512MB):
# NLP_MODEL=blanchefort/rubert-base-cased-sentiment

# LLM fallback для сарказма/мемов (опционально)
USE_LLM_FALLBACK=false
OPENAI_API_KEY=

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-please

# ─── База данных ──────────────────────────────────────────────────────────────
# SQLite для старта (нет зависимостей)
DATABASE_URL=sqlite+aiosqlite:///./moodex.db
# PostgreSQL для продакшна:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moodex

# Redis (опционально, для pub/sub алертов)
REDIS_URL=redis://localhost:6379/0

# ─── Настройки агрегатора ─────────────────────────────────────────────────────
# Временное окно для расчёта индекса (минуты)
SENTIMENT_WINDOW_MINUTES=60
# Мин. сообщений для значимого индекса
MIN_MESSAGES_FOR_SIGNAL=5
# Порог аномалии (×3 от среднего = аномальная активность)
ANOMALY_THRESHOLD=3.0
